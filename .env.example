APP_NAME="Московский паломник"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=palomnik
DB_USERNAME=root
DB_PASSWORD=

ADMIN_NAME="Главный администратор"
ADMIN_EMAIL=admin@palomnik.local
ADMIN_PASSWORD=

# Создание полного набора демонстрационных данных при php artisan db:seed.
DEMO_DATA_ENABLED=false

# MapLibre / OpenStreetMap / OpenMapTiles
# Внешний style.json имеет приоритет. Если он пуст, Laravel отдаёт /api/v1/map/style.json.
MAP_STYLE_URL=
# Пример собственного TileServer GL: http://127.0.0.1:8080/data/v3/{z}/{x}/{y}.pbf
OPENMAPTILES_TILE_URL=
# Пример: http://127.0.0.1:8080/fonts/{fontstack}/{range}.pbf
MAP_GLYPHS_URL=
# Резервный слой только для разработки. Публичный OSM tile server нельзя использовать для массовой офлайн-загрузки.
MAP_RASTER_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Необязательные лицензированные слои.
MAP_SATELLITE_TILE_URL=
MAP_HISTORIC_TILE_URL=
MAP_ATTRIBUTION="© OpenStreetMap contributors"
# Включайте только при собственном/лицензированном сервере тайлов.
MAP_OFFLINE_ENABLED=false
MAP_OFFLINE_TILE_LIMIT=100000
# Для production рекомендуется собственный Valhalla.
VALHALLA_URL=https://valhalla.openstreetmap.de
VALHALLA_TIMEOUT=20

PRIVACY_POLICY_VERSION=1.0

FIREBASE_PUSH_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=storage/app/firebase/service-account.json

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
